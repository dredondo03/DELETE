import os
import shutil

def organizar_carpeta(ruta):
    # Definimos los tipos de archivos y sus carpetas destino
    extensiones = {
        'Documentos': ['.pdf', '.docx', '.txt', '.pptx', '.xlsx'],
        'Imagenes': ['.jpg', '.jpeg', '.png', '.gif', '.svg'],
        'Videos': ['.mp4', '.mkv', '.mov', '.avi'],
        'Audio': ['.mp3', '.wav', '.flac'],
        'Ejecutables': ['.exe', '.msi', '.sh'],
        'Comprimidos': ['.zip', '.rar', '.7z', '.tar']
    }

    # Cambiar al directorio deseado
    os.chdir(ruta)

    for archivo in os.listdir():
        # Saltamos si es una carpeta
        if os.path.isdir(archivo):
            continue

        # Obtenemos la extensión del archivo
        nombre, ext = os.path.splitext(archivo)
        ext = ext.lower()

        # Buscamos a qué categoría pertenece
        movido = False
        for carpeta, lista_ext in extensiones.items():
            if ext in lista_ext:
                # Creamos la carpeta si no existe
                if not os.path.exists(carpeta):
                    os.makedirs(carpeta)
                
                # Movemos el archivo
                shutil.move(archivo, os.path.join(carpeta, archivo))
                print(f"Movido: {archivo} -> {carpeta}/")
                movido = True
                break
        
        if not movido:
            print(f"Omitido (sin categoría): {archivo}")

if __name__ == "__main__":
    # Cambia '.' por la ruta completa si quieres limpiar otra carpeta
    # Ejemplo: r"C:\Users\TuUsuario\Downloads"
    ruta_a_limpiar = "." 
    organizar_carpeta(ruta_a_limpiar)
    print("\n¡Limpieza completada!")
